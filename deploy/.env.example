APP_IMAGE=ghcr.io/mbonatte/tennis:latest
ENVIRONMENT=production
SECRET_KEY=replace-with-at-least-32-random-bytes
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_HOST=tennis-postgres
POSTGRES_PORT=5432
POSTGRES_DB=tennis
POSTGRES_USER=tennis
REDIS_URL=redis://redis:6379/0
DATA_ROOT=/app/data
MODEL_ROOT=/app/models
MAX_UPLOAD_BYTES=2147483648
MAX_VIDEO_DURATION_SECONDS=3600
MAX_VIDEO_WIDTH=3840
MAX_VIDEO_HEIGHT=2160
ALLOWED_VIDEO_EXTENSIONS=[".mp4",".mov",".mkv",".avi",".webm",".m4v"]
ALLOWED_VIDEO_CODECS=["h264","hevc","mpeg4","vp8","vp9","av1","mjpeg"]
JOB_TIMEOUT_SECONDS=7200
WORKER_CONCURRENCY=1
RETENTION_DAYS=30
LOG_LEVEL=INFO
DEVICE=cpu
ALLOWED_HOSTS=["tennis.example.com","localhost","127.0.0.1"]
PUBLIC_BASE_URL=https://tennis.example.com
ANALYSIS_CHUNK_FRAMES=256
